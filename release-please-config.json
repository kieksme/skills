{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "simple",
      "include-v-in-tag": false,
      "include-v-in-release-name": false,
      "extra-files": [
        "index.json",
        "docs/index.json"
      ],
      "changelog-sections": [
        {
          "type": "feat",
          "scope": "skills",
          "section": "Skills"
        },
        {
          "type": "feature",
          "scope": "skills",
          "section": "Skills"
        },
        {
          "type": "feat",
          "section": "Features"
        },
        {
          "type": "feature",
          "section": "Features"
        },
        {
          "type": "fix",
          "section": "Bug Fixes"
        },
        {
          "type": "perf",
          "section": "Performance Improvements"
        },
        {
          "type": "revert",
          "section": "Reverts"
        },
        {
          "type": "docs",
          "section": "Documentation"
        },
        {
          "type": "style",
          "section": "Styles"
        },
        {
          "type": "chore",
          "section": "Miscellaneous Chores"
        },
        {
          "type": "refactor",
          "section": "Code Refactoring"
        },
        {
          "type": "test",
          "section": "Tests"
        },
        {
          "type": "build",
          "section": "Build System"
        },
        {
          "type": "ci",
          "section": "Continuous Integration"
        }
      ]
    }
  }
}
