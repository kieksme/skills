---
import ToolPageTemplate from '../components/templates/ToolPageTemplate.astro';

interface Props {
  title: string;
  description?: string;
  heading?: string;
  subtitle?: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const {
  title,
  description,
  heading = title,
  subtitle = '',
  canonicalUrl,
  ogImage = '/skills/og/default.png'
} = Astro.props;

const baseUrl = '/skills/';
---

<ToolPageTemplate
  title={title}
  description={description}
  heading={heading}
  subtitle={subtitle}
  baseUrl={baseUrl}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
>
  <article class="rounded-xs border border-slate-200 bg-white p-6 dark:border-slate-700 dark:bg-slate-900 [&_h1]:mt-0 [&_h1]:text-3xl [&_h1]:font-bold [&_h2]:mt-8 [&_h2]:text-2xl [&_h2]:font-semibold [&_h3]:mt-6 [&_h3]:text-xl [&_h3]:font-semibold [&_p]:my-4 [&_p]:leading-7 [&_ul]:my-4 [&_ul]:list-disc [&_ul]:pl-6 [&_ol]:my-4 [&_ol]:list-decimal [&_ol]:pl-6 [&_li]:my-1 [&_a]:text-sky-700 dark:[&_a]:text-sky-400 [&_a]:no-underline hover:[&_a]:underline [&_pre]:my-4 [&_pre]:overflow-auto [&_pre]:rounded-xs [&_pre]:bg-slate-900 [&_pre]:p-4 [&_pre]:text-slate-200 [&_code]:rounded [&_code]:bg-slate-100 [&_code]:px-1 [&_code]:py-0.5 dark:[&_code]:bg-slate-800 dark:[&_code]:text-slate-200 [&_pre_code]:bg-transparent [&_pre_code]:p-0">
    <slot />
  </article>
</ToolPageTemplate>
