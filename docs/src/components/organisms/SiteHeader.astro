---
import MobileNavToggle from '../molecules/MobileNavToggle.astro';

interface Props {
  title: string;
  subtitle?: string;
  controlsId?: string;
  headerClass?: string;
  containerClass?: string;
  actionsClass?: string;
  showMobileToggle?: boolean;
}

const {
  title,
  subtitle,
  controlsId = 'mobile-nav-links',
  headerClass = 'bg-linear-to-b from-kieks-navy to-kieks-navy-deep py-12 text-white dark:bg-radial-[at_50%_100%] dark:from-slate-900 dark:via-slate-950 dark:to-slate-950',
  containerClass = 'mx-auto max-w-6xl px-4',
  actionsClass = 'mt-4 hidden flex-col gap-3 md:flex md:flex-row md:flex-wrap',
  showMobileToggle = true
} = Astro.props;
---

<header class:list={[headerClass, 'relative overflow-hidden']}>
  <div class="pointer-events-none absolute inset-0 hidden dark:block" aria-hidden="true">
    <div class="starfield-sky">
      <div class="starfield-gradient"></div>
      <div class="starfield-gradient starfield-gradient-secondary"></div>
      <span class="star star-a"></span>
      <span class="star star-b"></span>
      <span class="star star-c"></span>
      <span class="star star-d"></span>
      <span class="star star-e"></span>
      <span class="star star-f"></span>
      <span class="star star-g"></span>
      <span class="star star-h"></span>
      <span class="star star-i"></span>
      <span class="star star-j"></span>
    </div>
  </div>
  <div class="pointer-events-none absolute inset-0 hidden dark:block" aria-hidden="true">
    <span class="shooting-star" id="shooting-star"></span>
  </div>
  <div class="pointer-events-none absolute inset-0 hidden dark:block bg-linear-to-b from-transparent via-transparent to-slate-950/35" aria-hidden="true" />
  <div class:list={[containerClass, 'relative z-10']}>
    {showMobileToggle && <MobileNavToggle controlsId={controlsId} />}
    <div class={actionsClass} id={controlsId} data-open="false">
      <slot name="actions" />
    </div>
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">{title}</h1>
    {subtitle && <p class="mt-3 max-w-3xl text-slate-200 dark:text-slate-400">{subtitle}</p>}
    <slot />
  </div>
</header>

<script>
  const shootingStar = document.getElementById('shooting-star');

  if (shootingStar && window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
    const launch = () => {
      const startX = -12 + Math.random() * 30;
      const startY = 8 + Math.random() * 26;
      const travelY = 18 + Math.random() * 18;
      const angle = -14 - Math.random() * 16;
      const duration = 700 + Math.random() * 700;
      const trailLength = 70 + Math.random() * 55;

      shootingStar.style.setProperty('--shoot-start-x', `${startX}vw`);
      shootingStar.style.setProperty('--shoot-start-y', `${startY}%`);
      shootingStar.style.setProperty('--shoot-travel-y', `${travelY}vh`);
      shootingStar.style.setProperty('--shoot-angle', `${angle}deg`);
      shootingStar.style.setProperty('--shoot-duration', `${duration}ms`);
      shootingStar.style.setProperty('--shoot-length', `${trailLength}px`);

      shootingStar.classList.remove('is-active');
      // Force reflow so animation can restart.
      void shootingStar.offsetWidth;
      shootingStar.classList.add('is-active');
    };

    const scheduleNext = () => {
      // Random gap between 12s and 34s keeps it rare.
      const delay = 12000 + Math.random() * 22000;
      window.setTimeout(() => {
        launch();
        scheduleNext();
      }, delay);
    };

    scheduleNext();
  }
</script>

<style>
  .starfield-sky {
    position: absolute;
    left: 50%;
    top: 62%;
    width: 280%;
    height: 280%;
    transform: translate(-50%, -50%) rotate(0deg);
    animation: starfieldRotate 420s linear infinite;
    will-change: transform;
  }

  .starfield-gradient {
    position: absolute;
    inset: 0;
    background-repeat: no-repeat;
    background-image:
      radial-gradient(1px 1px at 12% 18%, rgba(255, 255, 255, 0.9) 99%, transparent 100%),
      radial-gradient(1px 1px at 28% 62%, rgba(226, 232, 240, 0.8) 99%, transparent 100%),
      radial-gradient(1.5px 1.5px at 44% 26%, rgba(255, 255, 255, 0.85) 99%, transparent 100%),
      radial-gradient(1px 1px at 58% 74%, rgba(148, 163, 184, 0.85) 99%, transparent 100%),
      radial-gradient(1.5px 1.5px at 72% 34%, rgba(255, 255, 255, 0.9) 99%, transparent 100%),
      radial-gradient(1px 1px at 86% 58%, rgba(226, 232, 240, 0.75) 99%, transparent 100%),
      radial-gradient(2px 2px at 20% 82%, rgba(255, 255, 255, 0.8) 99%, transparent 100%),
      radial-gradient(1.5px 1.5px at 76% 14%, rgba(255, 255, 255, 0.8) 99%, transparent 100%),
      radial-gradient(1px 1px at 6% 46%, rgba(226, 232, 240, 0.75) 99%, transparent 100%),
      radial-gradient(1.5px 1.5px at 17% 56%, rgba(255, 255, 255, 0.88) 99%, transparent 100%),
      radial-gradient(1px 1px at 35% 11%, rgba(226, 232, 240, 0.78) 99%, transparent 100%),
      radial-gradient(1px 1px at 48% 88%, rgba(255, 255, 255, 0.82) 99%, transparent 100%),
      radial-gradient(1.5px 1.5px at 67% 67%, rgba(255, 255, 255, 0.84) 99%, transparent 100%),
      radial-gradient(1px 1px at 79% 47%, rgba(148, 163, 184, 0.75) 99%, transparent 100%),
      radial-gradient(1px 1px at 93% 22%, rgba(255, 255, 255, 0.78) 99%, transparent 100%),
      radial-gradient(1px 1px at 14% 8%, rgba(255, 255, 255, 0.82) 99%, transparent 100%),
      radial-gradient(1.5px 1.5px at 22% 92%, rgba(226, 232, 240, 0.8) 99%, transparent 100%),
      radial-gradient(1px 1px at 31% 41%, rgba(255, 255, 255, 0.76) 99%, transparent 100%),
      radial-gradient(1px 1px at 52% 53%, rgba(226, 232, 240, 0.82) 99%, transparent 100%),
      radial-gradient(1.5px 1.5px at 64% 89%, rgba(255, 255, 255, 0.85) 99%, transparent 100%),
      radial-gradient(1px 1px at 74% 7%, rgba(148, 163, 184, 0.8) 99%, transparent 100%),
      radial-gradient(1px 1px at 88% 76%, rgba(255, 255, 255, 0.8) 99%, transparent 100%),
      radial-gradient(1px 1px at 97% 49%, rgba(226, 232, 240, 0.75) 99%, transparent 100%),
      radial-gradient(1px 1px at 4% 21%, rgba(255, 255, 255, 0.8) 99%, transparent 100%),
      radial-gradient(1px 1px at 8% 79%, rgba(226, 232, 240, 0.72) 99%, transparent 100%),
      radial-gradient(1px 1px at 10% 59%, rgba(255, 255, 255, 0.76) 99%, transparent 100%),
      radial-gradient(1px 1px at 15% 33%, rgba(226, 232, 240, 0.78) 99%, transparent 100%),
      radial-gradient(1px 1px at 18% 72%, rgba(255, 255, 255, 0.84) 99%, transparent 100%),
      radial-gradient(1px 1px at 24% 48%, rgba(148, 163, 184, 0.78) 99%, transparent 100%),
      radial-gradient(1px 1px at 26% 15%, rgba(255, 255, 255, 0.8) 99%, transparent 100%),
      radial-gradient(1px 1px at 29% 63%, rgba(226, 232, 240, 0.74) 99%, transparent 100%),
      radial-gradient(1px 1px at 34% 84%, rgba(255, 255, 255, 0.8) 99%, transparent 100%),
      radial-gradient(1px 1px at 38% 29%, rgba(226, 232, 240, 0.76) 99%, transparent 100%),
      radial-gradient(1px 1px at 41% 58%, rgba(255, 255, 255, 0.78) 99%, transparent 100%),
      radial-gradient(1px 1px at 45% 35%, rgba(226, 232, 240, 0.76) 99%, transparent 100%),
      radial-gradient(1px 1px at 49% 16%, rgba(255, 255, 255, 0.84) 99%, transparent 100%),
      radial-gradient(1px 1px at 54% 77%, rgba(226, 232, 240, 0.74) 99%, transparent 100%),
      radial-gradient(1px 1px at 59% 43%, rgba(255, 255, 255, 0.8) 99%, transparent 100%),
      radial-gradient(1px 1px at 62% 21%, rgba(226, 232, 240, 0.72) 99%, transparent 100%),
      radial-gradient(1px 1px at 66% 52%, rgba(255, 255, 255, 0.8) 99%, transparent 100%),
      radial-gradient(1px 1px at 69% 81%, rgba(148, 163, 184, 0.76) 99%, transparent 100%),
      radial-gradient(1px 1px at 73% 29%, rgba(255, 255, 255, 0.82) 99%, transparent 100%),
      radial-gradient(1px 1px at 77% 61%, rgba(226, 232, 240, 0.74) 99%, transparent 100%),
      radial-gradient(1px 1px at 82% 12%, rgba(255, 255, 255, 0.82) 99%, transparent 100%),
      radial-gradient(1px 1px at 84% 68%, rgba(226, 232, 240, 0.76) 99%, transparent 100%),
      radial-gradient(1px 1px at 89% 39%, rgba(255, 255, 255, 0.78) 99%, transparent 100%),
      radial-gradient(1px 1px at 91% 57%, rgba(226, 232, 240, 0.72) 99%, transparent 100%),
      radial-gradient(1px 1px at 95% 14%, rgba(255, 255, 255, 0.84) 99%, transparent 100%),
      radial-gradient(1px 1px at 98% 86%, rgba(226, 232, 240, 0.72) 99%, transparent 100%);
  }

  .starfield-gradient-secondary {
    transform: translate3d(1.8%, 2.2%, 0) scale(1.02);
    opacity: 0.9;
  }

  .star {
    position: absolute;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 0 10px rgba(255, 255, 255, 0.35);
    animation: starPulse 4.2s ease-in-out infinite;
  }

  .star-a {
    left: 24%;
    top: 22%;
    width: 2px;
    height: 2px;
    animation-delay: 0.4s;
  }

  .star-b {
    left: 63%;
    top: 38%;
    width: 2px;
    height: 2px;
    animation-delay: 1.3s;
  }

  .star-c {
    left: 81%;
    top: 19%;
    width: 3px;
    height: 3px;
    animation-delay: 2.1s;
  }

  .star-d {
    left: 11%;
    top: 69%;
    width: 2px;
    height: 2px;
    animation-delay: 0.9s;
  }

  .star-e {
    left: 39%;
    top: 73%;
    width: 2px;
    height: 2px;
    animation-delay: 2.8s;
  }

  .star-f {
    left: 57%;
    top: 12%;
    width: 1.5px;
    height: 1.5px;
    animation-delay: 1.7s;
  }

  .star-g {
    left: 92%;
    top: 44%;
    width: 2px;
    height: 2px;
    animation-delay: 3.4s;
  }

  .star-h {
    left: 27%;
    top: 86%;
    width: 2px;
    height: 2px;
    animation-delay: 2.3s;
  }

  .star-i {
    left: 71%;
    top: 24%;
    width: 2px;
    height: 2px;
    animation-delay: 3.1s;
  }

  .star-j {
    left: 46%;
    top: 6%;
    width: 1.5px;
    height: 1.5px;
    animation-delay: 1.1s;
  }

  @keyframes starPulse {
    0%,
    100% {
      opacity: 0.45;
      transform: scale(0.9);
    }
    50% {
      opacity: 1;
      transform: scale(1.25);
    }
  }

  @keyframes starfieldRotate {
    from {
      transform: translate(-50%, -50%) rotate(0deg);
    }
    to {
      transform: translate(-50%, -50%) rotate(360deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .starfield-sky {
      animation: none;
      transform: translate(-50%, -50%);
    }
  }

  .shooting-star {
    position: absolute;
    left: var(--shoot-start-x, -6vw);
    top: var(--shoot-start-y, 18%);
    width: var(--shoot-length, 92px);
    height: 1px;
    opacity: 0;
    transform: translate3d(0, 0, 0) rotate(var(--shoot-angle, -22deg));
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.95), rgba(226, 232, 240, 0.65) 28%, rgba(148, 163, 184, 0.2) 64%, rgba(148, 163, 184, 0));
    filter: drop-shadow(0 0 3px rgba(255, 255, 255, 0.35));
    transform-origin: left center;
  }

  .shooting-star.is-active {
    animation: shootingStar var(--shoot-duration, 1100ms) cubic-bezier(0.2, 0.6, 0.12, 1) forwards;
  }

  @keyframes shootingStar {
    0% {
      opacity: 0;
      transform: translate3d(0, 0, 0) rotate(var(--shoot-angle, -22deg));
    }
    10% {
      opacity: 0.9;
    }
    100% {
      opacity: 0;
      transform: translate3d(115vw, var(--shoot-travel-y, 30vh), 0) rotate(var(--shoot-angle, -22deg));
    }
  }
</style>
