---
import SearchInput from '../molecules/SearchInput.astro';

interface Props {
  scopes: string[];
  totalCount: number;
  scopeCounts: Record<string, number>;
}

const { scopes, totalCount, scopeCounts } = Astro.props;
---

<div class="relative mb-5">
  <SearchInput placeholder="Search skills by name or description..." />
  <div class="pointer-events-none absolute inset-y-0 right-3 hidden items-center gap-1 text-xs text-slate-400 dark:text-slate-500 sm:flex" aria-hidden="true">
    <kbd class="rounded border border-slate-200 bg-white px-1.5 py-0.5 font-mono text-[11px] text-slate-500 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-400">⌘K</kbd>
    <span>/</span>
    <kbd class="rounded border border-slate-200 bg-white px-1.5 py-0.5 font-mono text-[11px] text-slate-500 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-400">Ctrl+K</kbd>
  </div>
</div>

<div class="mb-4 flex flex-wrap gap-2" role="tablist" aria-label="Filter by scope">
  <button
    class="filter-tab active inline-flex items-center gap-1.5 rounded-xs border border-sky-600 bg-sky-600 px-3 py-1.5 text-xs font-medium text-white"
    data-scope="all"
    role="tab"
    aria-selected="true"
  >
    All <span class="tab-count inline-flex h-5 min-w-5 items-center justify-center rounded-full bg-white/25 px-1 text-[11px] font-semibold text-white">{totalCount}</span>
  </button>
  {scopes.map((scope) => (
    <button
      class="filter-tab inline-flex items-center gap-1.5 rounded-xs border border-slate-200 bg-white px-3 py-1.5 text-xs font-medium text-slate-700 transition hover:border-sky-400 hover:bg-sky-50 hover:text-sky-800 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-400 dark:hover:border-slate-600 dark:hover:bg-slate-800 dark:hover:text-slate-200"
      data-scope={scope}
      role="tab"
      aria-selected="false"
    >
      {scope}
      {' '}
      <span class="tab-count inline-flex h-5 min-w-5 items-center justify-center rounded-full bg-sky-100 px-1 text-[11px] font-semibold text-sky-700 dark:bg-slate-700 dark:text-slate-200">{scopeCounts[scope] ?? 0}</span>
    </button>
  ))}
</div>

<p class="mb-5 text-sm text-slate-500 dark:text-slate-400">
  Showing <strong id="visible-count" class="text-sky-700 dark:text-slate-200">{totalCount}</strong> skills
</p>
