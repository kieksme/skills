---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../organisms/SiteHeader.astro';
import FooterLinks from '../molecules/FooterLinks.astro';

interface Props {
  title: string;
  description?: string;
  heading: string;
  subtitle: string;
  baseUrl: string;
  /** Release/catalog version; shown in the footer. Omit to read from `index.json` at build time. */
  catalogVersion?: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const { title, description, heading, subtitle, baseUrl, catalogVersion, canonicalUrl, ogImage } = Astro.props;
---

<BaseLayout title={title} description={description} canonicalUrl={canonicalUrl} ogImage={ogImage}>
  <SiteHeader title={heading} subtitle={subtitle} showMobileToggle={false} />

  <main>
    <div class="mx-auto max-w-6xl px-4 py-8 pb-12">
      <slot />
    </div>
  </main>

  <FooterLinks
    links={[
      { href: 'https://kieksme.digital', label: 'kieksme' },
      { href: 'https://github.com/kieksmeRepo/tp-skills', label: 'GitHub' },
      { href: `${baseUrl}imprint/`, label: 'Imprint' }
    ]}
    prefix="Built by"
    catalogVersion={catalogVersion}
  />
</BaseLayout>
