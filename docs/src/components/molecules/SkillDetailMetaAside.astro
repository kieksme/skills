---
interface Props {
  skillMetadata: {
    title: string;
    description: string;
    purpose: string;
    tags: string[];
    source: string;
    version: string;
  } | null;
  lastUpdated: string | null;
}

const { skillMetadata, lastUpdated } = Astro.props;

function formatLastUpdated(value: string | null): string {
  if (!value) return 'No recent git history';
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return 'No recent git history';
  return new Intl.DateTimeFormat('en-US', { dateStyle: 'medium' }).format(date);
}
---

<aside class="rounded-xs border border-slate-200 bg-white p-4 dark:border-slate-700 dark:bg-slate-900 lg:sticky lg:top-24">
  <h2 class="text-sm font-semibold text-slate-900 dark:text-slate-100">Skill metadata</h2>
  {
    skillMetadata ? (
      <div class="mt-4 space-y-4 text-sm">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.08em] text-slate-500 dark:text-slate-400">Purpose</p>
          <p class="mt-1 text-slate-700 dark:text-slate-300">{skillMetadata.purpose}</p>
        </div>

        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.08em] text-slate-500 dark:text-slate-400">Tags</p>
          <div class="mt-2 flex flex-wrap gap-1.5">
            {skillMetadata.tags.map((tag) => (
              <span class="rounded-full border border-slate-300 bg-slate-100 px-2 py-0.5 text-xs text-slate-700 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-300">
                {tag}
              </span>
            ))}
          </div>
        </div>

        <div class="rounded-xs border border-slate-200 bg-slate-50 p-3 dark:border-slate-700 dark:bg-slate-800/50">
          <p class="text-xs font-semibold uppercase tracking-[0.08em] text-slate-500 dark:text-slate-400">Last updated</p>
          <p class="mt-1 text-slate-900 dark:text-slate-100">{formatLastUpdated(lastUpdated)}</p>
        </div>

        <dl class="space-y-3">
          <div>
            <dt class="text-xs font-semibold uppercase tracking-[0.08em] text-slate-500 dark:text-slate-400">Version</dt>
            <dd class="mt-1 text-slate-900 dark:text-slate-100">v{skillMetadata.version}</dd>
          </div>
          <div>
            <dt class="text-xs font-semibold uppercase tracking-[0.08em] text-slate-500 dark:text-slate-400">Source</dt>
            <dd class="mt-1">
              <a
                href={skillMetadata.source}
                target="_blank"
                rel="noopener noreferrer"
                class="break-all text-kieks-navy underline decoration-slate-300 underline-offset-2 hover:text-kieks-fuchsia dark:text-kieks-aqua dark:decoration-slate-600 dark:hover:text-kieks-aqua"
              >
                {skillMetadata.source}
              </a>
            </dd>
          </div>
        </dl>
      </div>
    ) : (
      <p class="mt-3 text-sm text-slate-500 dark:text-slate-400">No metadata found for this skill.</p>
    )
  }
</aside>
